# Common ignore rules for lab works 9-14

# OS and editor files
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo

# Python artifacts
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# Go artifacts
bin/
build/
dist/
*.exe
*.test
coverage.out

# Node artifacts, if a lab uses a web frontend
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Generated data, reports and temporary files
*.log
*.tmp
*.bak
*.zip
data/raw/*.jsonl
data/processed/*.parquet
reports/figures/*.png
